<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" text="Création de profil" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.views.ProfileModificatorView" >
   <VBox prefHeight="200.0" prefWidth="100.0">
      <Label text="Modifiez votre profil (/*￣︶￣)/">
         <font>
            <Font name="Consolas" size="28.0" />
         </font>
      </Label>
      <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text="Votre prénom" textAlignment="CENTER" translateX="30.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <TextField fx:id="firstname" translateX="100.0">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="52.0" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text="Votre nom" textAlignment="CENTER" translateX="30.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <TextField fx:id="lastname" translateX="132.0">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="152.0" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text=" Votre poid (en kg)" textAlignment="CENTER" translateX="30.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <TextField fx:id="weight" promptText="ex: 49" translateX="124.0">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="252.0" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text="Votre taille (en cm)" textAlignment="CENTER" translateX="30.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <TextField fx:id="height" promptText="ex: 159" translateX="130.0">
               <font>
                  <Font size="15.0" />
               </font>
            </TextField>
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="259.0" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text="Votre sexe" textAlignment="CENTER" translateX="30.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <RadioButton fx:id="maleButton" mnemonicParsing="false" text="♂" translateX="100.0">
               <toggleGroup>
                  <ToggleGroup fx:id="sex" />
               </toggleGroup></RadioButton>
            <RadioButton fx:id="femaleButton" layoutX="112.0" layoutY="29.0" mnemonicParsing="false" text="♀" toggleGroup="$sex" translateX="150.0" />
         </children>
      </HBox>
      <HBox alignment="CENTER_LEFT" layoutX="20.0" layoutY="273.0" prefHeight="100.0" prefWidth="200.0">
         <children>
            <Label text="Votre date de naissance" textAlignment="CENTER" translateX="30.0">
               <font>
                  <Font size="22.0" />
               </font>
            </Label>
            <DatePicker translateX="70.0" fx:id="birthdate"/>
         </children>
      </HBox>
      <Button alignment="CENTER" mnemonicParsing="false" onAction="#saveProfile" text="OK" textAlignment="CENTER" translateX="450.0">
         <font>
            <Font size="21.0" />
         </font>
      </Button>
   </VBox>
</TitledPane>
