<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<TitledPane animated="false" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" text="Add Activity" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.views.AddActivityController">
   <VBox prefHeight="200.0" prefWidth="100.0">
	  <Label text="Add your activity">
		 <font>
			<Font name="Consolas" size="28.0" />
		 </font>
	  </Label>
	   <HBox alignment="CENTER_LEFT" prefHeight="150.0" prefWidth="579.0">
		   <children>
			   <Label text="Sport" textAlignment="CENTER" translateX="30.0">
				   <font>
					   <Font size="22.0" />
				   </font>
			   </Label>
			   <ComboBox fx:id="cbSport" prefWidth="200.0" promptText="choose" translateX="80" />
		   </children>
	   </HBox>
	   <HBox alignment="CENTER_LEFT" prefHeight="300.0" prefWidth="600.0">
         <children>
			 <Label text="Intensity" textAlignment="CENTER" translateX="30.0">
				 <font>
					 <Font size="22.0" />
				 </font>
			 </Label>
            <Slider fx:id="intensity_slider" prefWidth="200.0"  translateX="50"/>
			 <TextField fx:id="intensity"  translateX="80">
				 <font>
					 <Font size="15.0" />
				 </font>
			 </TextField>
         </children>
	   </HBox>
	  <HBox alignment="CENTER_LEFT" prefHeight="200.0" prefWidth="600.0">
		 <children>
			<Label text="Duration" textAlignment="CENTER" translateX="30.0">
			   <font>
				  <Font size="22.0" />
			   </font>
			</Label>
			<TextField fx:id="duration" translateX="80.0">
			   <font>
				  <Font size="15.0" />
			   </font>
			</TextField>
		 </children>
	  </HBox>
	   <Button alignment="CENTER" mnemonicParsing="false" onAction="#saveActivity" text="OK" textAlignment="CENTER" translateX="450.0">
		   <font>
			   <Font size="21.0" />
		   </font>
	   </Button>

	</VBox>

</TitledPane>
