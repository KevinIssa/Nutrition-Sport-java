<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="406.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/17.0.2-ea" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ulb.views.MenuViewController">
   <children>
      <MenuBar prefHeight="38.0" prefWidth="700.0">
         <menus>
				<Menu>
					<graphic>
						<StackPane prefHeight="30" prefWidth="30">
							<!-- Create a Circle shape as the clip -->
							<clip>
								<Circle centerX="15" centerY="15" radius="15" />
							</clip>
							<!-- Create the ImageView with the image -->
							<Circle centerX="15" centerY="15" fill="WHITE" radius="15.0" stroke="BLACK" strokeType="INSIDE" />
							<ImageView fx:id="profileimage" fitHeight="30" fitWidth="30">
								<Image url="@../images/default_profile.png" />
							</ImageView>
						</StackPane>
					</graphic>
					<MenuItem onAction="#openProfile" text="Voir le profil" />
				</Menu>

                  				<Menu text="Historiques">
					<MenuItem onAction="#activityHistory" text="Des activités" />
               <MenuItem mnemonicParsing="false" onAction="#mealHistory" text="Des repas" />
				</Menu>
            <Menu mnemonicParsing="false">
               <graphic>
                  <Label alignment="CENTER" text="APPLICATION DE BIEN ÊTRE">
                     <font>
                        <Font size="19.0" />
                     </font>
                  </Label>
               </graphic>
            </Menu>
         </menus>
      </MenuBar>
      <VBox alignment="TOP_CENTER" layoutX="102.0" layoutY="40.0" prefHeight="363.0" prefWidth="488.0">
         <children>
            <ImageView fitHeight="290.0" fitWidth="348.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/menu_img/temp_graph.png" />
               </image>
            </ImageView>
         </children>
      </VBox>
      <Button fx:id="addButton" layoutX="637.0" layoutY="332.0" mnemonicParsing="false" onAction="#handleButtonPress" prefHeight="38.0" prefWidth="37.0">
         <font>
            <Font size="17.0" />
         </font>
         <graphic>
            <ImageView fitHeight="36.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/menu_img/add.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
      <Button fx:id="addFoodButton" layoutX="644.0" layoutY="276.0" mnemonicParsing="false" onAction="#foodSearchPage" prefHeight="38.0" prefWidth="37.0" visible="false">
         <font>
            <Font size="17.0" />
         </font>
         <graphic>
            <ImageView fitHeight="23.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/menu_img/addFood.png" />
               </image>
            </ImageView>
         </graphic>
      </Button>
      <Button fx:id="addActivityButton" layoutX="643.0" layoutY="227.0" mnemonicParsing="false" onAction="#createActivity" prefHeight="38.0" prefWidth="37.0" visible="false">
         <font>
            <Font size="17.0" />
         </font>
         <graphic>
            <ImageView fitHeight="23.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/sport_img/Course à pied.png" />
               </image></ImageView>
         </graphic>
      </Button>
   </children>
</AnchorPane>
