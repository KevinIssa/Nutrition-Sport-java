                  <Button mnemonicParsing="false" prefHeight="50.0" prefWidth="50.0" translateY="-480.0">
                     <graphic>
                        <ImageView fitHeight="40.0" fitWidth="40.0" pickOnBounds="true" preserveRatio="true">
